---
import jobsData from '../../data/jobs.json';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const GRACE_MS = 7 * 24 * 60 * 60 * 1000;
const activeJobs = jobsData.jobs.filter(
  (j) => j.isActive || Date.now() - new Date(j.lastSeen).getTime() <= GRACE_MS
);
const locations = [...new Set(activeJobs.map((j) => j.locationNormalised))].sort();

const normaliseType = (t: string | undefined) => {
  if (!t) return '';
  const l = t.toLowerCase();
  if (l.includes('part')) return 'part-time';
  if (l.includes('contract')) return 'contract';
  return 'full-time';
};
const types = ['full-time', 'part-time', 'contract'].filter(
  (t) => activeJobs.some((j) => normaliseType(j.type) === t)
);

const normaliseCategory = (dept: string | undefined, title: string) => {
  if (dept) {
    const d = dept.toLowerCase();
    if (d.includes('engineering') || d.includes('development') || d.includes('product') || d.includes('cloud') || d === 'data' || d.includes('bi &') || d.includes('data analysis') || d.includes('technology and tools') || d.includes('ux') || d.includes('trust')) return 'developer';
    if (d.includes('marketing') || d === 'sales' || d.includes('sales &') || d.includes('sales and')) return 'marketing-sales';
    if (d.includes('support function') || d.includes('managed service') || d.includes('service delivery') || d === 'delivery' || d.includes('delivery management') || d.includes('services :')) return 'support';
    if (d.includes('consult') || d.includes('enterprise agility') || d.includes('it strategy') || d.includes('transformation') || d.includes('business process') || d.includes('enterprise technology') || d.includes('work management') || d.includes('monday') || d.includes('contract service')) return 'consultancy';
    if (d.includes('finance') || d.includes('accounting') || d.includes('people experience') || d.includes('talent') || d.includes('shared services') || d.includes('sites')) return 'back-office';
  }
  const t = title.toLowerCase();
  if (t.includes('developer') || t.includes('engineer') || t.includes('architect') || t.includes('technical') || t.includes('data') || t.includes('cloud') || t.includes('product')) return 'developer';
  if (t.includes('consult') || t.includes('advisor') || t.includes('implementation') || t.includes('agile') || t.includes('scrum') || t.includes('migration')) return 'consultancy';
  if (t.includes('marketing') || t.includes('content') || t.includes('brand') || t.includes('sales') || t.includes('account manager') || t.includes('business development')) return 'marketing-sales';
  if (t.includes('support') || t.includes('service desk') || t.includes('helpdesk') || t.includes('customer success')) return 'support';
  if (t.includes('finance') || t.includes('payroll') || t.includes('accounting') || t.includes('recruit') || t.includes('talent') || t.includes('people ops') || t.includes('legal') || t.includes('compliance') || t.includes('office manager')) return 'back-office';
  return '';
};
const categories = ['developer', 'consultancy', 'marketing-sales', 'support', 'back-office'].filter(
  (c) => activeJobs.some((j) => normaliseCategory(j.department, j.title) === c)
);

const jobPostings = activeJobs.map((j) => ({
  '@type': 'JobPosting',
  title: j.title,
  description: j.description ?? `${j.title} position at ${j.company}.`,
  datePosted: j.firstSeen,
  validThrough: j.lastSeen,
  hiringOrganization: { '@type': 'Organization', name: j.company },
  jobLocation:
    j.locationNormalised === 'remote'
      ? { '@type': 'Place', address: { '@type': 'PostalAddress', addressCountry: 'AU' } }
      : { '@type': 'Place', address: j.location },
  ...(j.locationNormalised === 'remote' ? { jobLocationType: 'TELECOMMUTE' } : {}),
  url: j.url,
}));
---

<Layout
  title="Atlassian Ecosystem Jobs | Apwide"
  description={`${activeJobs.length} jobs at Atlassian Solution Partners and Marketplace vendors. Jira admins, Confluence specialists, and more. Updated weekly.`}
>
  {jobPostings.length > 0 && (
    <script
      is:inline
      type="application/ld+json"
      slot="head"
      set:html={JSON.stringify({ '@context': 'https://schema.org', '@graph': jobPostings })}
    />
  )}

  <Header />

  <main>
    <section class="jobs-hero container">
      <h1>Atlassian Ecosystem Jobs</h1>
      <p class="jobs-meta">
        {activeJobs.length > 0
          ? `${activeJobs.length} roles across Solution Partners and Marketplace vendors · updated weekly`
          : 'Jobs loading — check back soon'}
      </p>

      <p class="atlassian-link">
        Also hiring directly: <a href="https://www.atlassian.com/company/careers/all-jobs" target="_blank" rel="noopener noreferrer">Atlassian careers →</a>
      </p>

      <div class="jobs-filters">
        <input
          id="filter-title"
          type="search"
          placeholder="Search by title, keyword, or company…"
          autocomplete="off"
        />
        <select id="filter-location" aria-label="Filter by location">
          <option value="">All locations</option>
          {locations.map((l) => (
            <option value={l}>{l.charAt(0).toUpperCase() + l.slice(1)}</option>
          ))}
        </select>
        <select id="filter-type" aria-label="Filter by job type">
          <option value="">All job types</option>
          {types.map((t) => (
            <option value={t}>{t.charAt(0).toUpperCase() + t.slice(1)}</option>
          ))}
        </select>
        <select id="filter-category" aria-label="Filter by category">
          <option value="">All categories</option>
          {categories.map((c) => {
            const label = c === 'developer' ? 'Developer'
              : c === 'consultancy' ? 'Consultancy'
              : c === 'marketing-sales' ? 'Marketing and Sales'
              : c === 'support' ? 'Support'
              : 'Back-Office';
            return <option value={c}>{label}</option>;
          })}
        </select>
      </div>
    </section>

    <section class="container" style="padding-bottom: 80px;">
      <p id="no-results" hidden>No jobs match your search. Try different keywords or clear the filters.</p>

      <div id="job-results" class="job-grid">
        {activeJobs.map((job) => (
          <article
            class="job-card"
            data-title={`${job.title.toLowerCase()} ${job.company.toLowerCase()} ${(job.type ?? '').toLowerCase()} ${job.location.toLowerCase()} ${job.locationNormalised.toLowerCase()}`}
            data-location={job.locationNormalised}
            data-type={normaliseType(job.type)}
            data-category={normaliseCategory(job.department, job.title)}
          >
            <div class="job-card__meta">
              <span class="job-card__source">{job.source}</span>
              <span class="job-card__location">{job.location || 'Location not specified'}</span>
              {job.type && <span class="job-card__type">{job.type}</span>}
            </div>
            <h2 class="job-card__title">
              <a href={job.url} target="_blank" rel="noopener noreferrer">
                {job.title}
              </a>
            </h2>
            <p class="job-card__company">{job.company}</p>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const titleInput = document.getElementById('filter-title') as HTMLInputElement;
  const locationSelect = document.getElementById('filter-location') as HTMLSelectElement;
  const typeSelect = document.getElementById('filter-type') as HTMLSelectElement;
  const categorySelect = document.getElementById('filter-category') as HTMLSelectElement;
  const noResultsEl = document.getElementById('no-results') as HTMLParagraphElement;
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.job-card'));

  let debounceTimer: ReturnType<typeof setTimeout>;

  function filter() {
    const q = titleInput.value.toLowerCase();
    const loc = locationSelect.value;
    const type = typeSelect.value;
    const cat = categorySelect.value;
    let visible = 0;

    cards.forEach((card) => {
      const matchesTitle = !q || (card.dataset.title ?? '').includes(q);
      const matchesLocation = !loc || card.dataset.location === loc;
      const matchesType = !type || card.dataset.type === type;
      const matchesCategory = !cat || card.dataset.category === cat;
      card.hidden = !(matchesTitle && matchesLocation && matchesType && matchesCategory);
      if (!card.hidden) visible++;
    });

    noResultsEl.hidden = visible > 0;
  }

  titleInput.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(filter, 50);
  });

  locationSelect.addEventListener('change', filter);
  typeSelect.addEventListener('change', filter);
  categorySelect.addEventListener('change', filter);
</script>
