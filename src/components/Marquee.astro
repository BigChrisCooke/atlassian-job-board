---
const badges = [
  { src: '/images/atlassian-marketplace-partner.png', alt: 'Atlassian Marketplace Partner' },
  { src: '/images/award-government-partner.webp', alt: 'Government Partner of the Year APAC' },
  { src: '/images/award-ai-innovation.webp', alt: 'AI Innovation Partner' },
  { src: '/images/specialization-service-mgmt.png', alt: 'Service Management Specialization' },
  { src: '/images/atlassian-training-partner.png', alt: 'Atlassian Training Partner' },
  { src: '/images/award-work-management.webp', alt: 'Work Management Award' },
  { src: '/images/specialization-cloud.png', alt: 'Cloud Specialization' },
  { src: '/images/award-rising-star.png', alt: 'Rising Star Award' },
];
---

<section class="marquee-section section">
  <div class="container">
    <h2 class="marquee-heading">Trusted by Government and Enterprise</h2>
  </div>
  <div class="marquee-wrapper">
    <div class="marquee-track" style="animation: marquee 30s linear infinite;">
      {badges.map((badge) => (
        <div class="marquee-item">
          <img src={badge.src} alt={badge.alt} />
        </div>
      ))}
      {/* Duplicate for seamless loop */}
      {badges.map((badge) => (
        <div class="marquee-item">
          <img src={badge.src} alt={badge.alt} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-section {
    overflow: hidden;
    padding: 48px 0;
  }

  .marquee-heading {
    text-align: center;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 32px;
  }

  .marquee-wrapper {
    overflow: hidden;
    width: 100%;
  }

  .marquee-track {
    display: flex;
    gap: 48px;
    align-items: center;
    width: max-content;
  }

  .marquee-track:hover {
    animation-play-state: paused !important;
  }

  .marquee-item {
    flex-shrink: 0;
  }

  .marquee-item img {
    height: 80px;
    width: auto;
    object-fit: contain;
    filter: grayscale(0.2);
    transition: filter 0.3s;
  }

  .marquee-item img:hover {
    filter: grayscale(0);
  }

  @media (max-width: 768px) {
    .marquee-item img {
      height: 56px;
    }

    .marquee-track {
      gap: 32px;
    }

    .marquee-heading {
      font-size: 0.9rem;
    }
  }
</style>
