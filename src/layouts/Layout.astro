---
import '../styles/global.css';
import SEO from '../components/SEO.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title = 'Togetha Group - Work better Togetha',
  description = 'Togetha Group - Your Atlassian Platinum Solution Partner. Expert Atlassian solutions for Government and Enterprise.',
  ...seoProps
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <SEO title={title} description={description} {...seoProps} />

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
