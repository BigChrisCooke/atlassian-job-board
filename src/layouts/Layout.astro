---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title = 'Apwide - Atlassian Ecosystem Jobs',
  description = 'Apwide - Your Atlassian Platinum Solution Partner. Expert Atlassian solutions for Government and Enterprise.',
  ...seoProps
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <SEO title={title} description={description} {...seoProps} />

    <slot name="head" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NQ4BSEGLYS"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NQ4BSEGLYS');
    </script>
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>
